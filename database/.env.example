# Database Configuration
# Copy this file to .env and update the values

# PostgreSQL connection URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://adbar_user:adbar_password@localhost:5432/adbar_db?schema=public"

# Optional: Direct URL for Prisma migrations (bypasses connection pooler)
# DIRECT_URL="postgresql://adbar_user:adbar_password@localhost:5432/adbar_db?schema=public"

# Environment
NODE_ENV="development"
