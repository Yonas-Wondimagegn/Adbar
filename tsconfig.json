{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@adbar/common": ["backend/shared/common/src"],
      "@adbar/common/*": ["backend/shared/common/src/*"],
      "@adbar/middleware": ["backend/shared/middleware/src"],
      "@adbar/middleware/*": ["backend/shared/middleware/src/*"],
      "@adbar/events": ["backend/shared/events/src"],
      "@adbar/events/*": ["backend/shared/events/src/*"],
      "@adbar/auth": ["backend/services/auth/src"],
      "@adbar/user": ["backend/services/user/src"],
      "@adbar/product": ["backend/services/product/src"],
      "@adbar/order": ["backend/services/order/src"],
      "@adbar/payment": ["backend/services/payment/src"],
      "@adbar/escrow": ["backend/services/escrow/src"],
      "@adbar/wallet": ["backend/services/wallet/src"],
      "@adbar/freelance": ["backend/services/freelance/src"],
      "@adbar/job": ["backend/services/job/src"],
      "@adbar/contract": ["backend/services/contract/src"],
      "@adbar/messaging": ["backend/services/messaging/src"],
      "@adbar/notification": ["backend/services/notification/src"],
      "@adbar/search": ["backend/services/search/src"],
      "@adbar/review": ["backend/services/review/src"],
      "@adbar/dispute": ["backend/services/dispute/src"],
      "@adbar/kyc": ["backend/services/kyc/src"],
      "@adbar/ussd": ["backend/services/ussd/src"],
      "@adbar/analytics": ["backend/services/analytics/src"],
      "@adbar/ai-matching": ["backend/services/ai-matching/src"],
      "@adbar/admin": ["backend/services/admin/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
