# ============================================================
# Adbar Platform — Environment Variables (Example)
# Copy this file to .env and update values for your environment
# ============================================================

# ── Application ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_NAME=Adbar
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api/v1
FRONTEND_URL=http://localhost:3001
LOG_LEVEL=debug

# ── Database (PostgreSQL) ────────────────────────────────
DATABASE_URL=postgresql://adbar_user:adbar_password@localhost:5432/adbar_db?schema=public
DIRECT_URL=postgresql://adbar_user:adbar_password@localhost:5432/adbar_db?schema=public
POSTGRES_USER=adbar_user
POSTGRES_PASSWORD=adbar_password
POSTGRES_DB=adbar_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=adbar_redis_pass
REDIS_DB=0

# ── Elasticsearch ────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# ── Kafka ────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=adbar
KAFKA_GROUP_ID=adbar-group
KAFKA_SSL=false

# ── JWT & Authentication ─────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=adbar-auth

# ── OAuth Providers ──────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=./keys/apple-auth.p8
APPLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/apple/callback

# ── MFA ──────────────────────────────────────────────────
MFA_ISSUER=Adbar
MFA_ENCRYPTION_KEY=your-mfa-encryption-key-32-chars

# ── Payment Providers ────────────────────────────────────
# Chapa (Ethiopia)
CHAPA_API_KEY=your-chapa-api-key
CHAPA_SECRET_KEY=your-chapa-secret-key
CHAPA_BASE_URL=https://api.chapa.co/v1
CHAPA_WEBHOOK_SECRET=your-chapa-webhook-secret

# SantimPay (Ethiopia)
SANTIMPAY_API_KEY=your-santimpay-api-key
SANTIMPAY_SECRET_KEY=your-santimpay-secret-key
SANTIMPAY_BASE_URL=https://api.santimpay.com/v1

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# ── KYC / Identity Verification ──────────────────────────
# Fayda (Ethiopian National ID)
FAYDA_API_KEY=your-fayda-api-key
FAYDA_BASE_URL=https://api.fayda.gov.et/v1
FAYDA_CLIENT_ID=your-fayda-client-id
FAYDA_CLIENT_SECRET=your-fayda-client-secret

# Passport Verification
PASSPORT_API_KEY=your-passport-api-key
PASSPORT_BASE_URL=https://api.passport-verify.com/v1

# ── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@adbar.com
SMTP_FROM_NAME=Adbar Platform

# ── SMS ──────────────────────────────────────────────────
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# ── Push Notifications ──────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# ── Storage (S3 / MinIO) ─────────────────────────────────
STORAGE_PROVIDER=minio
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=adbar_minio
AWS_SECRET_ACCESS_KEY=adbar_minio_password
AWS_S3_BUCKET=adbar-uploads
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_FORCE_PATH_STYLE=true

# ── USSD Gateway ─────────────────────────────────────────
USSD_GATEWAY_URL=https://ussd-gateway.et/api/v1
USSD_API_KEY=your-ussd-api-key
USSD_SHORT_CODE=*808*
USSD_SESSION_TTL=120

# ── AI / ML Service ──────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_API_KEY=your-ai-service-api-key
OPENAI_API_KEY=your-openai-api-key

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3004

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# ── Encryption ───────────────────────────────────────────
ENCRYPTION_KEY=your-32-character-encryption-key
ENCRYPTION_ALGORITHM=aes-256-gcm

# ── Monitoring ───────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
DATADOG_API_KEY=

# ── Feature Flags ────────────────────────────────────────
FEATURE_FLAG_USSD=true
FEATURE_FLAG_AI_MATCHING=true
FEATURE_FLAG_ANALYTICS=true
FEATURE_FLAG_SOCIAL_LOGIN=true
