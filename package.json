{
  "name": "adbar",
  "version": "1.0.0",
  "description": "Adbar (አድባር) — Ethiopian Digital Marketplace & Freelance Platform",
  "private": true,
  "license": "UNLICENSED",
  "author": "Adbar Platform Team",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "backend/services/*",
    "backend/shared/*",
    "frontend/web"
  ],
  "overrides": {
    "postcss": "8.4.31"
  },
  "scripts": {
    "dev": "nx run-many --target=serve --all --parallel=20",
    "dev:gateway": "nx serve api-gateway",
    "build": "nx run-many --target=build --all",
    "build:affected": "nx affected --target=build",
    "test": "nx run-many --target=test --all",
    "test:affected": "nx affected --target=test",
    "test:e2e": "nx run-many --target=e2e --all",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "typecheck": "nx run-many --target=typecheck --all",
    "prisma:generate": "prisma generate --schema=database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=database/prisma/schema.prisma",
    "prisma:migrate:prod": "prisma migrate deploy --schema=database/prisma/schema.prisma",
    "prisma:seed": "ts-node database/seeds/seed.ts",
    "prisma:studio": "prisma studio --schema=database/prisma/schema.prisma",
    "db:seed": "npm run prisma:seed",
    "db:migrate": "npm run prisma:migrate",
    "docker:dev": "docker compose -f infrastructure/docker/docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose -f infrastructure/docker/docker-compose.dev.yml down",
    "docker:prod": "docker compose -f infrastructure/docker/docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f infrastructure/docker/docker-compose.prod.yml down",
    "docker:logs": "docker compose -f infrastructure/docker/docker-compose.dev.yml logs -f",
    "docker:clean": "docker compose -f infrastructure/docker/docker-compose.dev.yml down -v --remove-orphans",
    "k8s:dev": "kubectl apply -k infrastructure/kubernetes/overlays/dev",
    "k8s:staging": "kubectl apply -k infrastructure/kubernetes/overlays/staging",
    "k8s:prod": "kubectl apply -k infrastructure/kubernetes/overlays/prod",
    "prepare": "husky install || true"
  },
  "dependencies": {
    "@nestjs/axios": "^3.0.2",
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/platform-socket.io": "^10.3.10",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/websockets": "^10.3.10",
    "@next/env": "^16.2.9",
    "@prisma/client": "^5.17.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "axios": "^1.7.2",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "date-fns": "^3.6.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "kafkajs": "^2.2.4",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.35.2",
    "speakeasy": "^2.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@nestjs/cli": "^10.4.2",
    "@nestjs/schematics": "^10.1.2",
    "@nestjs/testing": "^10.3.10",
    "@nrwl/nx-cloud": "^19.0.0",
    "@nx/eslint": "^19.5.0",
    "@nx/jest": "^19.5.0",
    "@nx/js": "^19.5.0",
    "@nx/nest": "^19.5.0",
    "@nx/node": "^19.5.0",
    "@nx/webpack": "^19.5.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.7",
    "nx": "^19.5.0",
    "prettier": "^3.3.2",
    "prisma": "^5.17.0",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.3"
  },
  "prisma": {
    "schema": "database/prisma/schema.prisma",
    "seed": "ts-node database/seeds/seed.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
